# Admin Dashboard — Environment Variables
# Copy this file to .env and fill in real values

# Backend API URL
VITE_API_URL=http://localhost:8000/api/v1

# ── EmailJS (free) — https://emailjs.com ──────────────────────────────────────
# 1. Create free account at emailjs.com
# 2. Add an Email Service (Gmail, Outlook, etc.)
# 3. Create an Email Template with these variables:
#    {{to_email}}, {{to_name}}, {{subject}}, {{event_type}},
#    {{username}}, {{timestamp}}, {{ip}}, {{user_agent}}, {{site_url}}
# 4. Copy values from Dashboard
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ── Africa's Talking SMS (free sandbox) — https://account.africastalking.com ─
# Sandbox: use username=sandbox and your sandbox API key
# Production: use your real AT username and API key
VITE_AT_USERNAME=sandbox
VITE_AT_API_KEY=your_africastalking_api_key
